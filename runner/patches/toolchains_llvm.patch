diff --git a/toolchain/cc_toolchain_config.bzl b/toolchain/cc_toolchain_config.bzl
--- a/toolchain/cc_toolchain_config.bzl
+++ b/toolchain/cc_toolchain_config.bzl
@@ -191,10 +191,11 @@ def cc_toolchain_config(
     link_flags = [
         "--target=" + target_system_name,
         "-no-canonical-prefixes",
         "-fuse-ld=lld",
     ]

-    if exec_os == "darwin":
-        # These will get expanded by osx_cc_wrapper's `sanitize_option`
-        link_flags.append("--ld-path=ld64.lld" if target_os == "darwin" else "--ld-path=ld.lld")
+    if target_os == "darwin":
+        # These will get expanded by cc_wrapper's `sanitize_option`
+        link_flags.append("--ld-path=ld64.lld")
+    elif exec_os == "darwin":
+        link_flags.append("--ld-path=ld.lld")

     stdlib = compiler_configuration["stdlib"]
@@ -212,14 +213,13 @@ def cc_toolchain_config(
     is_darwin_exec_and_target = exec_os == "darwin" and target_os == "darwin"

     # Linker flags:
-    if is_darwin_exec_and_target:
+    if target_os == "darwin":
         link_flags.extend([
             "-headerpad_max_install_names",
             "-fobjc-link-runtime",
         ])

-        # Use the bundled libtool (llvm-libtool-darwin).
-        use_libtool = True
+        # Use the bundled libtool (llvm-libtool-darwin) only when exec is also darwin.
+        use_libtool = exec_os == "darwin"
     elif target_arch in ["wasm32", "wasm64"]:
         # lld is invoked as wasm-ld for WebAssembly targets.
         use_libtool = False
@@ -368,6 +368,6 @@ def cc_toolchain_config(
         "gcc": wrapper_bin_prefix + "cc_wrapper.sh",
         "gcov": tools_path_prefix + "llvm-profdata",
-        "ld": tools_path_prefix + "ld.lld",
+        "ld": tools_path_prefix + ("ld64.lld" if target_os == "darwin" else "ld.lld"),
         "llvm-cov": tools_path_prefix + "llvm-cov",
         "llvm-profdata": tools_path_prefix + "llvm-profdata",
         "nm": tools_path_prefix + "llvm-nm",
