# orion -> js cross-resolution.
#
# An orion plugin generates an esbuild bundle for each `*.app` marker. The bundle
# depends on a TypeScript entrypoint library that is owned by the NATIVE js
# gazelle extension (a rules_ts ts_project). The dependency is expressed as a
# "js"-provider Import, which the js extension resolves to its ts_project target
# in the sibling `src` package.
aspect.gazelle_rule_kind("esbuild_bundle", {
    "From": "@aspect_rules_esbuild//esbuild:defs.bzl",
    "ResolveAttrs": ["deps"],
})

def prepare(_):
    return aspect.PrepareResult(
        sources = [aspect.SourceExtensions(".app")],
    )

def declare(ctx):
    for f in ctx.sources:
        if f.path.endswith(".app"):
            name = f.path[:-len(".app")]
            ctx.targets.add(
                name = name,
                kind = "esbuild_bundle",
                attrs = {
                    # Bundle the app entrypoint from the js-managed `src` library.
                    "deps": [aspect.Import(id = "src/index", provider = "js")],
                },
            )

aspect.orion_extension(
    id = "esbuild-bundle",
    prepare = prepare,
    declare = declare,
)
