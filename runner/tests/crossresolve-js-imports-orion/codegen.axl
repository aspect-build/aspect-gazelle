# js -> orion cross-resolution.
#
# An orion plugin runs TypeScript codegen for each `*.graphql` schema, producing
# a generated module (queries.graphql -> the importable `./queries.generated`
# module). It registers a "js"-provider Symbol for that module so that native
# TypeScript imports of `./queries.generated` (handled by the js gazelle
# extension) resolve to this codegen target.
aspect.gazelle_rule_kind("graphql_ts_codegen", {
    "From": "@aspect_rules_graphql//graphql:defs.bzl",
    "NonEmptyAttrs": ["srcs"],
})

def prepare(_):
    return aspect.PrepareResult(
        sources = [aspect.SourceExtensions(".graphql")],
    )

def declare(ctx):
    for f in ctx.sources:
        if f.path.endswith(".graphql"):
            base = f.path[:-len(".graphql")]
            ctx.targets.add(
                name = base + "_graphql",
                kind = "graphql_ts_codegen",
                attrs = {"srcs": [f.path]},
                symbols = [aspect.Symbol(
                    id = path.join(ctx.rel, base + ".generated"),
                    provider = "js",
                )],
            )

aspect.orion_extension(
    id = "graphql-ts-codegen",
    prepare = prepare,
    declare = declare,
)
