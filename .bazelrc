import %workspace%/tools/preset.bazelrc
import %workspace%/tools/buildbuddy.bazelrc

common --config=ruleset

# Suppress Apple linker (Xcode 15+) duplicate library warnings from CGO
# When multiple CGO libraries each link -lm, ld emits "ignoring duplicate libraries: '-lm'"
build:macos --linkopt=-Wl,-no_warn_duplicate_libraries

# Build without the bytes
common:ci --remote_download_outputs=minimal
common:ci --nobuild_runfile_links

# Override the preset's `--lockfile_mode=error` on CI: we don't commit
# MODULE.bazel.lock (see .gitignore), so there's nothing to enforce against.
common:ci --lockfile_mode=off
