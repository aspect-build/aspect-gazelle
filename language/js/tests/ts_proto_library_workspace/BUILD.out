load("@aspect_rules_ts//ts:proto.bzl", "ts_proto_library")
load("@com_google_protobuf//bazel:proto_library.bzl", "proto_library")

proto_library(
    name = "lib_proto",
    srcs = ["lib.proto"],
    visibility = ["//visibility:public"],
)

ts_proto_library(
    name = "lib_proto_ts",
    proto = ":lib_proto",
    proto_srcs = ["lib.proto"],
)
