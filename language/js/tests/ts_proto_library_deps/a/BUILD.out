load("@aspect_rules_ts//ts:proto.bzl", "ts_proto_library")
load("@protobuf//bazel:proto_library.bzl", "proto_library")

proto_library(
    name = "a_proto",
    srcs = ["lib.proto"],
    visibility = ["//visibility:public"],
    deps = ["@protobuf//:duration_proto"],
)

ts_proto_library(
    name = "a_proto_ts",
    proto = ":a_proto",
    proto_srcs = ["lib.proto"],
)
