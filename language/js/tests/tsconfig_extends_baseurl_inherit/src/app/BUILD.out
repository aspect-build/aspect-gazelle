load("@aspect_rules_ts//ts:defs.bzl", "ts_config", "ts_project")

ts_project(
    name = "app",
    srcs = ["main.ts"],
    tsconfig = ":tsconfig",
    deps = ["//src/lib/util"],
)

ts_config(
    name = "tsconfig",
    src = "tsconfig.json",
    visibility = [":__subpackages__"],
    deps = ["//:tsconfig"],
)
