load("@aspect_rules_ts//ts:defs.bzl", "ts_config", "ts_project")

ts_config(
    name = "tsconfig.base",
    src = "tsconfig.base.json",
    visibility = [":__subpackages__"],
)

ts_project(
    name = "inherited",
    srcs = ["src/main.ts"],
    root_dir = "src",
    tsconfig = ":tsconfig",
)

ts_config(
    name = "tsconfig",
    src = "tsconfig.json",
    visibility = [":__subpackages__"],
    deps = [":tsconfig.base"],
)
