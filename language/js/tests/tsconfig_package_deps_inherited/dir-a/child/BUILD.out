load("@aspect_rules_ts//ts:defs.bzl", "ts_config", "ts_project")

# gazelle:js_tsconfig_package_deps enabled

ts_project(
    name = "child",
    srcs = ["main.ts"],
    tsconfig = ":tsconfig",
)

ts_config(
    name = "tsconfig",
    src = "tsconfig.json",
    visibility = [":__subpackages__"],
    deps = ["//dir-a:package.json"],
)
