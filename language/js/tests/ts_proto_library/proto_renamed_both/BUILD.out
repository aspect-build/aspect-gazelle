load("@aspect_rules_ts//ts:proto.bzl", "ts_proto_library")
load("@protobuf//bazel:proto_library.bzl", "proto_library")

proto_library(
    name = "bar_proto",
    srcs = ["bar.proto"],
    visibility = ["//visibility:public"],
)

ts_proto_library(
    name = "bar_proto_ts",
    node_modules = "//:node_modules",
    proto = ":bar_proto",
    proto_srcs = ["bar.proto"],
)
