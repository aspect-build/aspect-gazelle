load("@aspect_rules_js//js:defs.bzl", "js_library")
load("@npm//:defs.bzl", "npm_link_all_packages")

# The '.' export resolves (via js_resolve) to an npm package whose name
# contains a dot ('lodash.debounce'). It is a library target and must be
# classified by how it resolved, not by the dot in its label name.
# gazelle:js_resolve exports-npm/index.mjs //:node_modules/lodash.debounce

npm_link_all_packages(name = "node_modules")

js_library(
    name = "pkg",
    srcs = ["package.json"],
    visibility = ["//:__pkg__"],
    deps = ["//:node_modules/lodash.debounce"],
)
