load("@aspect_rules_js//js:defs.bzl", "js_library")
load("@aspect_rules_ts//ts:defs.bzl", "ts_project")
load("@npm//:defs.bzl", "npm_link_all_packages")

# gazelle:js_files testing_api testing.ts

npm_link_all_packages(name = "node_modules")

ts_project(
    name = "tsc",
    srcs = ["index.ts"],
)

ts_project(
    name = "testing_api",
    srcs = ["testing.ts"],
)

js_library(
    name = "pkg",
    srcs = ["package.json"],
    visibility = ["//:__pkg__"],
    deps = [
        ":testing_api",
        ":tsc",
    ],
)
