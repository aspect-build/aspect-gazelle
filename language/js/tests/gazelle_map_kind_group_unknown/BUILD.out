load("@aspect_rules_ts//ts:defs.bzl", "ts_project")

# The map_kind names a group ("speshul") that does not exist (the group is
# "special"): the directive is ignored with a warning and the group generates
# a plain ts_project.
# gazelle:js_files special *.special.ts
# gazelle:map_kind ts_project:speshul special_project //tools:special.bzl

ts_project(
    name = "gazelle_map_kind_group_unknown",
    srcs = ["a.ts"],
)

ts_project(
    name = "special",
    srcs = ["a.special.ts"],
)
