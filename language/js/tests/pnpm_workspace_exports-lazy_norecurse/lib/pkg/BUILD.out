load("@aspect_rules_ts//ts:defs.bzl", "ts_project")
load("@npm//:defs.bzl", "npm_link_all_packages")

# Disable the npm_package target so the self-references are resolved purely
# from the source ts_project. With an npm_package the package.json 'exports'
# entries are also indexed via the generated package rule, which would mask
# whether the source target itself declares the self-reference target
# directories for lazy indexing (see tsPackageInfoToRelsToIndex). '*' patterns
# such as './feat/*' are never enumerated as package entries, so they always
# rely on this path.
# gazelle:js_npm_package disabled

npm_link_all_packages(name = "node_modules")

ts_project(
    name = "pkg",
    srcs = ["index.ts"],
    deps = [
        "//lib/pkg/feat",
        "//lib/pkg/sub",
    ],
)
