load("@aspect_rules_ts//ts:defs.bzl", "ts_config", "ts_project")

# Validate the js_tsconfig_package_deps directive:
# - Same package: package.json is added to the ts_config rule's deps.
# - Child Bazel package with package.json (no local tsconfig.json): a ts_config
#   rule is generated whose src is the parent's ts_config rule and whose deps
#   include the local package.json.

# gazelle:js_tsconfig_package_deps enabled

ts_project(
    name = "tsconfig_package_deps",
    srcs = ["main.ts"],
    tsconfig = ":tsconfig",
)

ts_config(
    name = "tsconfig",
    src = "tsconfig.json",
    visibility = [":__subpackages__"],
    deps = [":package.json"],
)
