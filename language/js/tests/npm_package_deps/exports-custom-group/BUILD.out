load("@aspect_rules_js//npm:defs.bzl", "npm_package")
load("@aspect_rules_ts//ts:defs.bzl", "ts_project")
load("@npm//:defs.bzl", "npm_link_all_packages")

# gazelle:js_files testing_api testing.ts

npm_link_all_packages(name = "node_modules")

ts_project(
    name = "tsc",
    srcs = ["index.ts"],
)

ts_project(
    name = "testing_api",
    srcs = ["testing.ts"],
)

npm_package(
    name = "pkg",
    srcs = [
        "package.json",
        ":testing_api",
        ":tsc",
    ],
    visibility = ["//:__pkg__"],
)
