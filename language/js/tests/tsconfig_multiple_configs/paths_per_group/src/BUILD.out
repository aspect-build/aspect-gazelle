load("@aspect_rules_ts//ts:defs.bzl", "ts_project")

ts_project(
    name = "src",
    srcs = ["app.ts"],
    composite = True,
    tsconfig = "//paths_per_group:tsconfig_lib",
    deps = [
        "//:node_modules/tslib",
        "//paths_per_group/shared",
    ],
)

ts_project(
    name = "src_tests",
    testonly = True,
    srcs = ["app.spec.ts"],
    composite = True,
    tsconfig = "//paths_per_group:tsconfig_test",
    deps = [
        "//:node_modules/tslib",
        "//paths_per_group/test-helpers",
    ],
)
