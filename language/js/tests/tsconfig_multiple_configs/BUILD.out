load("@aspect_rules_ts//ts:defs.bzl", "ts_config")
load("@npm//:defs.bzl", "npm_link_all_packages")

# gazelle:js_tsconfig_file tsconfig.lib.json
# gazelle:js_tsconfig_file {dirname}_tests tsconfig.test.json

# Test ignore for a group
# gazelle:js_tsconfig_ignore {dirname}_e2e composite
# Test ignore for all groups
# gazelle:js_tsconfig_ignore incremental

# gazelle:js_test_files {dirname}_tests **/*.{test,spec}.{ts,tsx,mjs,mts}
# gazelle:js_test_files {dirname}_e2e **/*.e2e.ts
# gazelle:js_tsconfig_file {dirname}_e2e tsconfig.e2e.json

ts_config(
    name = "tsconfig_base",
    src = "tsconfig.base.json",
    visibility = ["//visibility:public"],
)

npm_link_all_packages(name = "node_modules")

ts_config(
    name = "tsconfig_e2e",
    src = "tsconfig.e2e.json",
    visibility = [":__subpackages__"],
    deps = [":tsconfig_base"],
)

ts_config(
    name = "tsconfig_lib",
    src = "tsconfig.lib.json",
    visibility = [":__subpackages__"],
    deps = [":tsconfig_base"],
)

ts_config(
    name = "tsconfig_test",
    src = "tsconfig.test.json",
    visibility = [":__subpackages__"],
    deps = [
        ":node_modules/jest",
        ":tsconfig_base",
        ":tsconfig_lib",
    ],
)
