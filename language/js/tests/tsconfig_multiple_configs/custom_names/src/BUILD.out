load("@aspect_rules_ts//ts:defs.bzl", "ts_project")

ts_project(
    name = "src_lib",
    srcs = ["app.ts"],
    composite = True,
    tsconfig = "//custom_names:tsconfig_lib",
    deps = ["//:node_modules/tslib"],
)

ts_project(
    name = "src_unit_tests",
    testonly = True,
    srcs = ["app.spec.ts"],
    composite = True,
    tsconfig = "//:tsconfig_test",
    deps = [
        ":src_lib",
        "//:node_modules/tslib",
    ],
)
