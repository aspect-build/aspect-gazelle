load("@aspect_rules_ts//ts:defs.bzl", "ts_config", "ts_project")

ts_config(
    name = "sibling",
    src = "sibling.json",
    visibility = [":__subpackages__"],
)

ts_project(
    name = "sub",
    srcs = ["main.ts"],
    composite = True,
    tsconfig = ":tsconfig",
)

ts_config(
    name = "tsconfig",
    src = "tsconfig.json",
    visibility = [":__subpackages__"],
    deps = [":sibling"],
)
