load("@aspect_rules_ts//ts:defs.bzl", "ts_project")

# Default + custom group both `# keep` `util.ts`; neither should dep on the other.
# gazelle:js_files extras b.ts

ts_project(
    name = "same_pkg",
    srcs = [
        "a.ts",
        "util.ts",  # keep
    ],
)

ts_project(
    name = "extras",
    srcs = [
        "b.ts",
        "util.ts",  # keep
    ],
)
