ts_project(
    name = "root",
    srcs = ["main.ts"],
    assets = [
        "logo.svg",
        "styles.css",
    ],
)

ts_project(
    name = "mygroup",
    srcs = ["lib.my.ts"],
    assets = ["data/sample.json"],
)
