load("@aspect_rules_ts//ts:defs.bzl", "ts_config", "ts_project")

# Validate that every package.json file inside the same Bazel package is added
# to the root ts_config rule's deps. The subdirectories deliberately have no
# BUILD files of their own so they remain part of the root Bazel package, and
# generation_mode update_only ensures gazelle does not create BUILD files in
# them during the test.
#
# The 'app' package additionally covers a base directory with a local
# tsconfig.json but no package.json of its own: its own files resolve to the
# closest ancestor package.json (//:package.json), so that must be in deps
# alongside the swept-in app/sub/package.json.
#
# The 'fwd' package has neither a local tsconfig.json nor a package.json of its
# own, only a swept-in fwd/sub/package.json: a forwarding ts_config rule must
# still be emitted to carry that package.json (and the ancestor) into scope.

# gazelle:generation_mode update_only
# gazelle:js_tsconfig_package_deps enabled

ts_project(
    name = "tsconfig_package_deps_multi",
    srcs = ["main.ts"],
    tsconfig = ":tsconfig",
)

ts_config(
    name = "tsconfig",
    src = "tsconfig.json",
    visibility = [":__subpackages__"],
    deps = [
        ":package.json",
        ":pkg-a/package.json",
        ":pkg-b/nested/package.json",
    ],
)
