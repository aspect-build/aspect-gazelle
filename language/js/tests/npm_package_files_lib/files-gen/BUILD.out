load("@aspect_rules_js//js:defs.bzl", "js_library")
load("@npm//:defs.bzl", "npm_link_all_packages")

genrule(
    name = "build",
    srcs = [],
    outs = ["dist/bundle.js"],
    cmd = "echo \"console.log(42)\" > \"$@\"",
)

npm_link_all_packages(name = "node_modules")

js_library(
    name = "pkg",
    srcs = ["package.json"],
    visibility = ["//:__pkg__"],
    deps = [":dist/bundle.js"],
)
