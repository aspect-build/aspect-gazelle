# Generates a `filegroup` rule without registering "filegroup" via
# aspect.gazelle_rule_kind(). `filegroup` is a generic bazel kind known
# to gazelle (rule.GenericKinds) so the extension is allowed to emit it
# directly.

def prepare(_):
    return aspect.PrepareResult(
        sources = [aspect.SourceExtensions(".txt")],
    )

def declare(ctx):
    if not ctx.sources:
        return

    ctx.targets.add(
        name = "all-files",
        kind = "filegroup",
        attrs = {
            "srcs": [s.path for s in ctx.sources],
        },
    )

aspect.orion_extension(
    id = "fg-builtin",
    prepare = prepare,
    declare = declare,
)
