load("@ancestor-test//:rules.bzl", "cfg_consumer")

# Override an ancestor import via the standard gazelle:resolve directive.
# Format: gazelle:resolve <import-lang> <resolver-lang> <import> <label>
# Here cfg-test is the import's provider type and orion is the resolver language.
# gazelle:resolve cfg-test orion config //elsewhere:override-target

cfg_consumer(
    name = "consumer",
    cfg = "//elsewhere:override-target",
)
