# `copy_to_bin` is a built-in rule kind (see builtin.go: registered with
# From="@bazel_lib//lib:copy_to_bin.bzl"). This extension re-registers
# "copy_to_bin" as loaded from a custom .bzl. Current behavior: the builtin
# is silently overwritten and generated BUILD files now emit a load() from
# the overriding .bzl.
aspect.gazelle_rule_kind("copy_to_bin", {
    "From": "@my_rules//:defs.bzl",
    "NonEmptyAttrs": ["srcs"],
    "MergeableAttrs": ["srcs"],
})

def prepare(_):
    return aspect.PrepareResult(
        sources = [aspect.SourceGlobs("**/*.axl")],
    )

def declare(ctx):
    if not ctx.sources:
        return
    ctx.targets.add(
        name = "all-files",
        kind = "copy_to_bin",
        attrs = {
            "srcs": [s.path for s in ctx.sources],
        },
    )

aspect.orion_extension(
    id = "ctb-override",
    prepare = prepare,
    declare = declare,
)
