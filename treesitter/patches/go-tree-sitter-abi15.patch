+static inline TSLexMode ts_language_lex_mode(const TSLanguage *language, TSStateId state) {
+  if (language->version >= 15) {
+    const TSLexerMode *mode = &((const TSLexerMode *)language->lex_modes)[state];
+    TSLexMode result;
+    result.lex_state = mode->lex_state;
+    result.external_lex_state = mode->external_lex_state;
+    // reserved_word_set_id (ABI 15) is intentionally not copied: this ABI 14 parser has no
+    // reserved-word-set logic, so the field would be unused regardless.
+    return result;
+  }
+  return language->lex_modes[state];
